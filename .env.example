# Auto-generated by Relayra setup wizard
# See GUIDE.md for documentation

# Auto-generated machine identity (DO NOT CHANGE)
RELAYRA_MACHINE_ID=
RELAYRA_INSTANCE_NAME=MY_SERVER

# Role: "listener" or "sender"
RELAYRA_ROLE=listener

# Network - address and port to bind
RELAYRA_LISTEN_ADDR=0.0.0.0
RELAYRA_LISTEN_PORT=8443
# Public IP for pairing tokens (Listener only - the IP Senders connect to)
RELAYRA_PUBLIC_ADDR=

# Storage backend: "redis" or "sqlite"
RELAYRA_STORAGE_BACKEND=redis
RELAYRA_SQLITE_PATH=/opt/relayra/relayra.db

# Redis connection
RELAYRA_REDIS_ADDR=127.0.0.1
RELAYRA_REDIS_PORT=6379
RELAYRA_REDIS_PASSWORD=
RELAYRA_REDIS_DB=0

# Polling settings (Sender only)
RELAYRA_POLL_INTERVAL=5
RELAYRA_POLL_BATCH_SIZE=10
RELAYRA_REQUEST_TIMEOUT=30
RELAYRA_LONG_POLLING=true
RELAYRA_LONG_POLL_WAIT=30
RELAYRA_ASYNC_WORKERS=4

# Execution
RELAYRA_ALLOW_LISTENER_EXECUTION=false

# Logging
RELAYRA_LOG_LEVEL=info
RELAYRA_LOG_DIR=/opt/relayra/logs
RELAYRA_LOG_MAX_DAYS=7

# Results & Webhook
RELAYRA_RESULT_TTL=86400
RELAYRA_WEBHOOK_MAX_RETRIES=3
